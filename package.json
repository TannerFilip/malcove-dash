{
  "name": "malcove-dash",
  "version": "1.0.0",
  "description": "Threat infrastructure triage dashboard",
  "scripts": {
    "dev": "concurrently --kill-others --names vite,wrangler --prefix-colors cyan,yellow \"vite\" \"wrangler pages dev --proxy 5173 --compatibility-date=2024-09-23 --compatibility-flags=nodejs_compat\"",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply malcove-dash --local",
    "db:migrate:remote": "wrangler d1 migrations apply malcove-dash --remote",
    "cf:deploy": "npm run build && wrangler pages deploy dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wrangler": "^4.86.0"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/router-vite-plugin": "^1.166.43",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "nanoid": "^5.1.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.4.3"
  }
}
